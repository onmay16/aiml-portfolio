---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AlgorithmFramework from '../../components/AlgorithmFramework';
import NeuralNetworkSlides from '../../components/NeuralNetworkSlides';
import AIInfrastructureSlides from '../../components/AIInfrastructureSlides';
import ExplainabilityInfographic from '../../components/ExplainabilityInfographic';
import ModelSelectionMatrix from '../../components/ModelSelectionMatrix';
import DeliverablesGallery from '../../components/DeliverablesGallery';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const artifacts = await getCollection('artifacts');
  return artifacts.map((artifact) => ({
    params: { slug: artifact.slug },
    props: { artifact },
  }));
}

const { artifact } = Astro.props;
const base = import.meta.env.BASE_URL;
const {
  title,
  introduction,
  description,
  objective,
  process,
  tools,
  valueProposition,
  references,
  deliverables,
} = artifact.data;
const { Content } = await artifact.render();
---

<BaseLayout title={title} description={introduction}>
  <article class="artifact-detail">
    <header class="page-header">
      <div class="container">
        <p class="section-label">Artifact</p>
        <h1>{title}</h1>
        <p class="artifact-meta">{introduction}</p>
        <p style="margin-top: 1rem;">
          <a href={`${base}artifacts/`}>← Back to all artifacts</a>
        </p>
      </div>
    </header>

    <div class="container section" style="padding-top: 0;">
      <section class="detail-section">
        <h2>Introduction</h2>
        <p>{introduction}</p>
      </section>

      <section class="detail-section">
        <h2>Description</h2>
        <p>{description}</p>
      </section>

      {artifact.data.interactive === 'algorithm-framework' && (
        <section class="detail-section" id="visual-framework">
          <h2>Visual Framework</h2>
          <AlgorithmFramework
            client:load
            subtitle="Explore how ML algorithms relate by learning style and application domain."
          />
        </section>
      )}

      {artifact.data.interactive === 'neural-network-slides' && (
        <section class="detail-section" id="visual-presentation">
          <h2>Visual Presentation</h2>
          <p>
            Interactive slide deck covering neural network architecture and six core components. Use the
            arrows or dots below to navigate like a presentation.
          </p>
          <NeuralNetworkSlides client:load />
        </section>
      )}

      {artifact.data.interactive === 'ai-infrastructure-slides' && (
        <section class="detail-section" id="visual-presentation">
          <h2>Visual Presentation</h2>
          <p>
            Interactive slide deck covering LLM training infrastructure, resource costs, and real-world model
            examples. Use the arrows or dots below to navigate like a presentation.
          </p>
          <AIInfrastructureSlides client:load />
        </section>
      )}

      {artifact.data.interactive === 'explainability-infographic' && (
        <section class="detail-section" id="visual-infographic">
          <h2>Interactive Infographic</h2>
          <ExplainabilityInfographic client:load />
        </section>
      )}

      {artifact.data.interactive === 'model-selection-matrix' && (
        <section class="detail-section" id="decision-matrix">
          <h2>Interactive Decision Matrix</h2>
          <p>
            Explore five pre-trained models across NLP, vision, and tabular domains. Click a table row,
            trade-off insight, or recommendation to see expanded analysis below the matrix.
          </p>
          <ModelSelectionMatrix client:load />
        </section>
      )}

      {Content && (
        <section class="detail-section artifact-markdown">
          <Content />
        </section>
      )}

      {objective && (
        <section class="detail-section">
          <h2>Objective</h2>
          <p>{objective}</p>
        </section>
      )}

      {process && (
        <section class="detail-section">
          <h2>Process</h2>
          <p>{process}</p>
        </section>
      )}

      {tools.length > 0 && (
        <section class="detail-section">
          <h2>Tools and Technologies Used</h2>
          <div class="artifact-card-tools">
            {tools.map((tool) => (
              <span class="tag">{tool}</span>
            ))}
          </div>
        </section>
      )}

      {valueProposition && (
        <section class="detail-section">
          <h2>Value Proposition</h2>
          <div class="value-prop-grid">
            <div class="value-prop-box">
              <h3>Unique Value</h3>
              <p>{valueProposition.uniqueValue}</p>
            </div>
            <div class="value-prop-box">
              <h3>Relevance</h3>
              <p>{valueProposition.relevance}</p>
            </div>
          </div>
        </section>
      )}

      {references && references.length > 0 && (
        <section class="detail-section">
          <h2>References</h2>
          <ul class="references-list">
            {references.map((ref) => (
              <li>{ref}</li>
            ))}
          </ul>
        </section>
      )}

      {deliverables.length > 0 && (
        <section class="detail-section">
          <h2>Deliverables</h2>
          <DeliverablesGallery client:load deliverables={deliverables} baseUrl={base} />
        </section>
      )}
    </div>
  </article>
</BaseLayout>
