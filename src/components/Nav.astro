---
import ThemeToggle from './ThemeToggle';
import { site } from '../data/site';

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const isArtifacts = path.includes('/artifacts');
const isHome = !isArtifacts;
---

<a href={base} class="brand">{site.name}</a>
<nav aria-label="Main navigation">
  <ul class="nav-links">
    <li>
      <a href={base} aria-current={isHome ? 'page' : undefined}>Home</a>
    </li>
    <li>
      <a href={`${base}artifacts/`} aria-current={isArtifacts ? 'page' : undefined}>Artifacts</a>
    </li>
  </ul>
</nav>
<div class="nav-actions">
  <ThemeToggle client:load />
</div>
